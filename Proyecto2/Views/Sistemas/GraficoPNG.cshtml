@using Proyecto2.Models
@using Proyecto2.TDAs
@{
    SistemaDrones? sistema = ViewBag.Sistema as SistemaDrones;
    string nombreSistema = ViewBag.NombreSistema as string ?? "";
    string imagenPath = ViewBag.ImagenPath as string ?? "";
}

<h2>Grafico del Sistema: @nombreSistema</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!string.IsNullOrEmpty(imagenPath))
{
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4>Tabla de Codificacion</h4>
        </div>
        <div class="card-body text-center">
            <img src="@imagenPath" alt="Tabla de codificacion del sistema" class="img-fluid" style="max-width: 100%;" />
        </div>
        <div class="card-footer text-muted">
            <small>Imagen generada con Graphviz - Tabla de codificacion</small>
        </div>
    </div>
}
else if (sistema != null)
{
    <div class="card">
        <div class="card-header bg-info text-white">
            <h4>Informacion del Sistema</h4>
        </div>
        <div class="card-body">
            <p><strong>Nombre:</strong> @sistema.Nombre</p>
            <p><strong>Cantidad de Drones:</strong> @sistema.Drones.Count</p>
            <p><strong>Codificaciones:</strong> @sistema.Codificacion.Count</p>
        </div>
    </div>
    
    <div class="alert alert-warning mt-3">
        <h5>No se pudo generar la imagen</h5>
        <p>Verifique que Graphviz este instalado en su sistema.</p>
        <p>Puede descargarlo desde <a href="https://graphviz.org/download/" target="_blank">https://graphviz.org/download/</a></p>
    </div>
}

<div class="mt-3">
    <a href="/Sistemas/Detalle?nombre=@nombreSistema" class="btn btn-primary">Volver al Detalle</a>
    <a href="/Sistemas/Index" class="btn btn-secondary">Volver a Sistemas</a>
</div>