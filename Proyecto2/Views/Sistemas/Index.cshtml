@using Proyecto2.TDAs
@model ListaSistemasDrones

@{
    ViewData["Title"] = "Sistemas de Drones";
}

<h2>Sistemas de Drones</h2>

<div class="mb-3">
    <a href="/Sistemas/Crear" class="btn btn-primary">Crear Nuevo Sistema</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        No hay sistemas registrados. <a href="/Sistemas/Crear">Cree uno nuevo</a>
    </div>
}
else
{
    <div class="row">
        @{
            var actual = Model.GetPrimero();
            while (actual != null)
            {
                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-header bg-primary text-white">
                            <h5 class="mb-0">@actual.Data.Nombre</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Drones:</strong> @actual.Data.Drones.Count</p>
                            <p><strong>Codificaciones:</strong> @actual.Data.Codificacion.Count</p>
                        </div>
                        <div class="card-footer">
                            <div class="btn-group w-100" role="group">
                                <a href="/Sistemas/Detalle?nombre=@actual.Data.Nombre" class="btn btn-info btn-sm">Detalle</a>
                                <a href="/Sistemas/GraficoPNG?nombre=@actual.Data.Nombre" class="btn btn-secondary btn-sm">Gráfico</a>
                                <form action="/Sistemas/Eliminar" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="nombre" value="@actual.Data.Nombre" />
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar este sistema?')">Eliminar</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                actual = actual.Siguiente;
            }
        }
    </div>
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">← Volver al Inicio</a>
</div>