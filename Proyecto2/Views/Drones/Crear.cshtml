@{
    ViewData["Title"] = "Crear Dron";
}

<h2>Crear Nuevo Dron</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form asp-action="Crear" method="post">
    <div class="mb-3">
        <label class="form-label">Nombre del Dron</label>
        <input type="text" name="nombre" class="form-control" required />
        <small class="form-text text-muted">Ejemplo: Dron05, DronAlpha, etc.</small>
    </div>
    
    <div class="mb-3">
        <label class="form-label">Altura Inicial (metros)</label>
        <input type="number" name="alturaInicial" class="form-control" value="1" min="1" max="100" />
        <small class="form-text text-muted">Entre 1 y 100 metros</small>
    </div>
    
    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>