@using Proyecto2.TDAs
@model ListaDrones

@{
    ViewData["Title"] = "Gestión de Drones";
}

<h2>Gestión de Drones</h2>

<div class="mb-3">
    <a href="/Drones/Crear" class="btn btn-primary"> Agregar Nuevo Dron</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Altura Actual</th>
            <th>Altura Inicial</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @{
            var actual = Model.GetPrimero();
            while (actual != null)
            {
                <tr>
                    <td>@actual.Data.Nombre</td>
                    <td>@actual.Data.AlturaActual m</td>
                    <td>@actual.Data.AlturaInicial m</td>
                    <td>
                        <form action="/Drones/Eliminar" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="nombre" value="@actual.Data.Nombre" />
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar este dron?')">🗑️ Eliminar</button>
                        </form>
                    </td>
                </tr>
                actual = actual.Siguiente;
            }
        }
    </tbody>
</table>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        No hay drones registrados. <a href="/Drones/Crear">Agregue uno nuevo</a>
    </div>
}

<div class="mt-3">
    <a href="/" class="btn btn-secondary">← Volver al Inicio</a>
</div>