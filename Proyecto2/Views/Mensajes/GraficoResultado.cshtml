@{
    ViewData["Title"] = "Grafico del Plan de Vuelo";
    string imagenPath = ViewBag.ImagenPath as string ?? "";
    string nombreMensaje = ViewBag.NombreMensaje as string ?? "";
    string nombreSistema = ViewBag.NombreSistema as string ?? "";
    int tiempoOptimo = ViewBag.TiempoOptimo ?? 0;
    string mensajeRecibido = ViewBag.MensajeRecibido as string ?? "";
}

<h2>Grafico del Plan de Vuelo</h2>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-success text-white">
                <h4>Resumen</h4>
            </div>
            <div class="card-body">
                <p><strong>Mensaje:</strong> @nombreMensaje</p>
                <p><strong>Sistema:</strong> @nombreSistema</p>
                <p><strong>Tiempo Optimo:</strong> @tiempoOptimo segundos</p>
                <p><strong>Mensaje Recibido:</strong> <code>@mensajeRecibido</code></p>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4>Secuencia de Instrucciones</h4>
            </div>
            <div class="card-body text-center">
                @if (!string.IsNullOrEmpty(imagenPath))
                {
                    <img src="@imagenPath" alt="Plan de vuelo" class="img-fluid" style="max-width: 100%;" />
                }
                else
                {
                    <div class="alert alert-warning">
                        No se pudo generar la imagen. Verifique que Graphviz este instalado.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a href="/Mensajes/Detalle?nombre=@nombreMensaje" class="btn btn-primary">Volver al Detalle</a>
    <a href="/Mensajes/Index" class="btn btn-secondary">Volver a Mensajes</a>
</div>