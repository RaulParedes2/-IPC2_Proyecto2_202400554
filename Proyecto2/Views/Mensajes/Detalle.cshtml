@using Proyecto2.Models
@using Proyecto2.TDAs
@model Mensaje

@{
    ViewData["Title"] = $"Detalle - {Model.Nombre}";
    ListaSistemasDrones sistemas = ViewBag.Sistemas as ListaSistemasDrones ?? new ListaSistemasDrones();
    SistemaDrones? sistemaSeleccionado = ViewBag.SistemaSeleccionado as SistemaDrones;
    string sistemaSeleccionadoNombre = ViewBag.SistemaSeleccionadoNombre as string ?? "";
}

<h2 class="mb-4">Mensaje: @Model.Nombre</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Columna Izquierda: Información y Formularios -->
    <div class="col-md-5">
        <!-- Tarjeta de Información -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-info-circle"></i> Información del Mensaje</h5>
            </div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Nombre:</div>
                    <div class="col-8"><strong>@Model.Nombre</strong></div>
                </div>
                <div class="row mb-2">
                    <div class="col-4 fw-bold">Texto Original:</div>
                    <div class="col-8">
                        @if (string.IsNullOrEmpty(Model.TextoOriginal))
                        {
                            <span class="text-muted fst-italic">(Sin texto)</span>
                        }
                        else
                        {
                            @Model.TextoOriginal
                        }
                    </div>
                </div>
                <div class="row">
                    <div class="col-4 fw-bold">Instrucciones:</div>
                    <div class="col-8">
                        <span class="badge bg-primary rounded-pill">@Model.Instrucciones.Count</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tarjeta de Selección de Sistema -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-grid"></i> Seleccionar Sistema</h5>
            </div>
            <div class="card-body">
                <form method="get" asp-action="Detalle">
                    <input type="hidden" name="nombre" value="@Model.Nombre" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Sistema de Drones</label>
                        <select name="sistema" class="form-select" onchange="this.form.submit()">
                            <option value="">-- Seleccione un sistema --</option>
                            @{
                                var sistemaActual = sistemas.GetPrimero();
                                while (sistemaActual != null)
                                {
                                    if (sistemaSeleccionadoNombre == sistemaActual.Data.Nombre)
                                    {
                                        <option value="@sistemaActual.Data.Nombre" selected>@sistemaActual.Data.Nombre</option>
                                    }
                                    else
                                    {
                                        <option value="@sistemaActual.Data.Nombre">@sistemaActual.Data.Nombre</option>
                                    }
                                    sistemaActual = sistemaActual.Siguiente;
                                }
                            }
                        </select>
                        <div class="form-text">Seleccione un sistema para ver sus drones disponibles</div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Tarjeta de Agregar Instrucción (solo si hay sistema seleccionado) -->
        @if (sistemaSeleccionado != null)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Agregar Instrucción</h5>
                </div>
                <div class="card-body">
                    <form asp-action="AgregarInstruccion" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="nombreMensaje" value="@Model.Nombre" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Dron</label>
                            <select name="nombreDron" class="form-select" required>
                                <option value="">-- Seleccione un dron --</option>
                                @{
                                    var dronSistema = sistemaSeleccionado.Drones.ObtenerOrdenadosAlfabeticamente().GetPrimero();
                                    while (dronSistema != null)
                                    {
                                        <option value="@dronSistema.Data.Nombre">@dronSistema.Data.Nombre</option>
                                        dronSistema = dronSistema.Siguiente;
                                    }
                                }
                            </select>
                            <div class="form-text">Drones disponibles en <strong>@sistemaSeleccionado.Nombre</strong></div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Altura (1-100)</label>
                            <input type="number" name="altura" class="form-control" min="1" max="100" required />
                            <div class="form-text">La letra se obtendrá automáticamente de la codificación del sistema</div>
                        </div>
                        
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-plus-circle"></i> Agregar Instrucción
                        </button>
                    </form>
                </div>
            </div>
        }

        <!-- Tarjeta de Enviar Mensaje -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-send"></i> Enviar Mensaje</h5>
            </div>
            <div class="card-body">
                <form action="/Mensajes/EnviarMensaje" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="nombreMensaje" value="@Model.Nombre" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Sistema de Drones</label>
                        <select name="nombreSistema" class="form-select" required>
                            <option value="">-- Seleccione un sistema --</option>
                            @{
                                var sistemaEnvio = sistemas.GetPrimero();
                                while (sistemaEnvio != null)
                                {
                                    <option value="@sistemaEnvio.Data.Nombre">@sistemaEnvio.Data.Nombre</option>
                                    sistemaEnvio = sistemaEnvio.Siguiente;
                                }
                            }
                        </select>
                        <div class="form-text">Seleccione el sistema al que desea enviar el mensaje</div>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-send"></i> Enviar Mensaje
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Columna Derecha: Lista de Instrucciones -->
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="bi bi-list-check"></i> Instrucciones del Mensaje</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.Instrucciones.Count == 0)
                {
                    <div class="alert alert-info m-3">
                        <i class="bi bi-info-circle"></i> No hay instrucciones configuradas.
                        Seleccione un sistema y agregue instrucciones.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered mb-0">
                            <thead class="table-dark">
                                <tr class="text-center">
                                    <th style="width: 10%">#</th>
                                    <th style="width: 35%">Dron</th>
                                    <th style="width: 25%">Altura</th>
                                    <th style="width: 30%">Letra</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var instruccionActual = Model.Instrucciones.GetPrimero();
                                    int index = 1;
                                    while (instruccionActual != null)
                                    {
                                        <tr>
                                            <td class="text-center fw-bold">@index</td>
                                            <td><strong>@instruccionActual.Data.NombreDron</strong></td>
                                            <td class="text-center">@instruccionActual.Data.AlturaObjetivo m</td>
                                            <td class="text-center">
                                                @if (instruccionActual.Data.LetraRepresenta == ' ')
                                                {
                                                    <span class="badge bg-warning text-dark" style="font-size: 0.9rem;">
                                                        <i class="bi bi-space"></i> [ESPACIO]
                                                    </span>
                                                }
                                                else if (instruccionActual.Data.LetraRepresenta != '?')
                                                {
                                                    <span class="badge bg-success" style="font-size: 1rem;">
                                                        '@instruccionActual.Data.LetraRepresenta'
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Pendiente</span>
                                                }
                                            </td>
                                        </tr>
                                        instruccionActual = instruccionActual.Siguiente;
                                        index++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-4 d-flex gap-2">
    <a href="/Mensajes/Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Volver a la lista
    </a>
    <a href="/Mensajes/GraficoPlan?nombre=@Model.Nombre" class="btn btn-info">
        <i class="bi bi-graph-up"></i> Ver Gráfico
    </a>
</div>

<!-- Agregar estilos para iconos si no están disponibles -->
<style>
    /* Si no tienes Bootstrap Icons, usa emojis como fallback */
    .bi::before {
        content: "";
        display: inline-block;
        width: 1em;
    }
</style>