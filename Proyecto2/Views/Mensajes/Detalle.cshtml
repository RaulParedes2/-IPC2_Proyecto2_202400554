@using Proyecto2.Models
@using Proyecto2.TDAs
@model Mensaje

@{
    ViewData["Title"] = $"Detalle - {Model.Nombre}";
    ListaSistemasDrones sistemas = ViewBag.Sistemas as ListaSistemasDrones ?? new ListaSistemasDrones();
}

<h2>Mensaje: @Model.Nombre</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row">
    <!-- Información del mensaje -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4>Información</h4>
            </div>
            <div class="card-body">
                <p><strong>Nombre:</strong> @Model.Nombre</p>
                <p><strong>Texto Original:</strong> @Model.TextoOriginal</p>
                <p><strong>Instrucciones:</strong> @Model.Instrucciones.Count</p>
            </div>
        </div>
        
        <!-- Enviar mensaje -->
        <div class="card mt-3">
            <div class="card-header">
                <h4>Enviar Mensaje</h4>
            </div>
            <div class="card-body">
                <form asp-action="EnviarMensaje" method="post">
                    <input type="hidden" name="nombreMensaje" value="@Model.Nombre" />
                    <div class="mb-3">
                        <label class="form-label">Seleccionar Sistema de Drones</label>
                        <select name="nombreSistema" class="form-select" required>
                            <option value="">-- Seleccione un sistema --</option>
                            @{
                                var sistemaActual = sistemas.GetPrimero();
                                while (sistemaActual != null)
                                {
                                    <option value="@sistemaActual.Data.Nombre">@sistemaActual.Data.Nombre</option>
                                    sistemaActual = sistemaActual.Siguiente;
                                }
                            }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-success">Enviar Mensaje</button>
                </form>
            </div>
        </div>
    </div>
    
    <!-- Lista de instrucciones -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4>Instrucciones del Mensaje</h4>
            </div>
            <div class="card-body">
                @if (Model.Instrucciones.Count == 0)
                {
                    <p class="text-muted">No hay instrucciones configuradas</p>
                }
                else
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Dron</th>
                                <th>Altura</th>
                                <th>Letra</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var instruccionActual = Model.Instrucciones.GetPrimero();
                                int index = 1;
                                while (instruccionActual != null)
                                {
                                    <tr>
                                        <td>@index</td>
                                        <td>@instruccionActual.Data.NombreDron</td>
                                        <td>@instruccionActual.Data.AlturaObjetivo m</td>
                                        <td><strong>'@instruccionActual.Data.LetraRepresenta'</strong></td>
                                    </tr>
                                    instruccionActual = instruccionActual.Siguiente;
                                    index++;
                                }
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
        
        <!-- Agregar instrucción -->
        <div class="card mt-3">
            <div class="card-header">
                <h4>Agregar Instrucción</h4>
            </div>
            <div class="card-body">
                <form asp-action="AgregarInstruccion" method="post">
                    <input type="hidden" name="nombreMensaje" value="@Model.Nombre" />
                    <div class="mb-3">
                        <label class="form-label">Dron</label>
                        <input type="text" name="nombreDron" class="form-control" placeholder="Ej: Dron01" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Altura (1-100)</label>
                        <input type="number" name="altura" class="form-control" min="1" max="100" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Letra</label>
                        <input type="text" name="letra" class="form-control" maxlength="1" required />
                    </div>
                    <button type="submit" class="btn btn-primary">Agregar Instrucción</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
    <a asp-action="GraficoPlan" asp-route-nombre="@Model.Nombre" class="btn btn-info">Ver Gráfico</a>
</div>