@{
    ViewData["Title"] = "Resultado del Envio";
    int tiempoOptimo = TempData["TiempoOptimo"] != null ? Convert.ToInt32(TempData["TiempoOptimo"]) : 0;
    string mensajeRecibido = TempData["MensajeRecibido"] as string ?? "";
    string nombreMensaje = TempData["NombreMensaje"] as string ?? "";
    string nombreSistema = TempData["NombreSistema"] as string ?? "";
    string imagenPath = TempData["ImagenPath"] as string ?? "";
}

<h2>Resultado del Envio</h2>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h4>Resumen</h4>
            </div>
            <div class="card-body">
                <p><strong>Mensaje:</strong> @nombreMensaje</p>
                <p><strong>Sistema:</strong> @nombreSistema</p>
                <p><strong>Tiempo Optimo:</strong> @tiempoOptimo segundos</p>
                <p><strong>Mensaje Recibido:</strong> <code class="fs-5">@mensajeRecibido</code></p>
            </div>
        </div>
        
        <div class="card">
            <div class="card-header bg-info text-white">
                <h4>Acciones</h4>
            </div>
            <div class="card-body">
                <a href="/Mensajes/Detalle?nombre=@nombreMensaje" class="btn btn-primary w-100 mb-2">Volver al Detalle</a>
                <a href="/Mensajes/Index" class="btn btn-secondary w-100">Volver a Mensajes</a>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4>Secuencia de Instrucciones</h4>
            </div>
            <div class="card-body text-center">
                @if (!string.IsNullOrEmpty(imagenPath))
                {
                    <img src="@imagenPath" alt="Plan de vuelo" class="img-fluid" style="max-width: 100%;" />
                    <p class="mt-2 text-muted">Imagen generada con Graphviz</p>
                }
                else
                {
                    <div class="alert alert-warning">
                        <h5>No se pudo generar la imagen</h5>
                        <p>Verifique que Graphviz este instalado en su sistema.</p>
                        <p>Puede descargarlo desde <a href="https://graphviz.org/download/" target="_blank">https://graphviz.org/download/</a></p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>