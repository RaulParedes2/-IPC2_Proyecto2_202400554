@{
    ViewData["Title"] = "Resultado del Envío";
    string planVuelo = ViewBag.PlanVuelo as string ?? "";
    int tiempoOptimo = ViewBag.TiempoOptimo ?? 0;
    string mensajeRecibido = ViewBag.MensajeRecibido as string ?? "";
    string nombreMensaje = ViewBag.NombreMensaje as string ?? "";
    string nombreSistema = ViewBag.NombreSistema as string ?? "";
}

<h2>Resultado del Envío</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4>Resumen</h4>
            </div>
            <div class="card-body">
                <p><strong>Mensaje:</strong> @nombreMensaje</p>
                <p><strong>Sistema:</strong> @nombreSistema</p>
                <p><strong>Tiempo Óptimo:</strong> @tiempoOptimo segundos</p>
                <p><strong>Mensaje Recibido:</strong> @mensajeRecibido</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4>XML de Salida</h4>
            </div>
            <div class="card-body">
                <pre class="bg-light p-3" style="overflow-x: auto; max-height: 400px;">@planVuelo</pre>
                <button class="btn btn-primary mt-2" onclick="copiarAlPortapapeles()">Copiar XML</button>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver a Mensajes</a>
    <a asp-action="Detalle" asp-route-nombre="@nombreMensaje" class="btn btn-info">Ver Detalle</a>
</div>

<script>
    function copiarAlPortapapeles() {
        const codigo = document.querySelector('pre').innerText;
        navigator.clipboard.writeText(codigo).then(() => {
            alert('XML copiado al portapapeles');
        });
    }
</script>