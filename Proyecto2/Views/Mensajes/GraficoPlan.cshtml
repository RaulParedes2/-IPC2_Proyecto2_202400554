@using Proyecto2.Models
@using Proyecto2.TDAs
@{
    Mensaje? mensaje = ViewBag.Mensaje as Mensaje;
    ListaSistemasDrones sistemas = ViewBag.Sistemas as ListaSistemasDrones ?? new ListaSistemasDrones();
    string nombreMensaje = mensaje?.Nombre ?? "";
}

<h2>Gráfico del Plan de Vuelo</h2>
<h4>Mensaje: @nombreMensaje</h4>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h4>Seleccionar Sistema de Drones</h4>
    </div>
    <div class="card-body">
        <form asp-action="GenerarGrafico" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="nombreMensaje" value="@nombreMensaje" />
            <div class="mb-3">
                <label class="form-label">Sistema de Drones</label>
                <select name="nombreSistema" class="form-select" required>
                    <option value="">-- Seleccione un sistema --</option>
                    @{
                        var sistemaActual = sistemas.GetPrimero();
                        while (sistemaActual != null)
                        {
                            <option value="@sistemaActual.Data.Nombre">@sistemaActual.Data.Nombre</option>
                            sistemaActual = sistemaActual.Siguiente;
                        }
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary"> Generar Gráfico</button>
        </form>
    </div>
</div>

<div class="mt-3">
    <a href="/Mensajes/Detalle?nombre=@nombreMensaje" class="btn btn-secondary">← Volver al Detalle</a>
    <a href="/Mensajes/Index" class="btn btn-secondary">Volver a Mensajes</a>
</div>