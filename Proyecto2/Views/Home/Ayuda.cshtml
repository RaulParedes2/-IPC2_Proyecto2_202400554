@{
    ViewData["Title"] = "Ayuda - Sistema de Drones";
}

<h2>Ayuda del Sistema</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white">
                <h4>Información del Estudiante</h4>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <th style="width: 120px">Nombre:</th>
                        <td>Raul Jose Daniel Paredes Gonzalez</td>
                    </tr>
                    <tr>
                        <th>Carnet:</th>
                        <td>202400554</td>
                    </tr>
                    <tr>
                        <th>Curso:</th>
                        <td>Introducción a la Programación y Computación 2</td>
                    </tr>
                    <tr>
                        <th>Sección:</th>
                        <td>A</td>
                    </tr>
                    <tr>
                        <th>Fecha:</th>
                        <td>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header bg-info text-white">
                <h4>Enlaces del Proyecto</h4>
            </div>
            <div class="card-body">
                <ul class="list-group">
                    <li class="list-group-item">
                        <strong>Repositorio GitHub:</strong>
                        <a href="https://github.com/RaulParedes2/-IPC2_Proyecto2_202400554" target="_blank">
                            IPC2_Proyecto2_202400554
                        </a>
                    </li>
                    <li class="list-group-item">
                        <strong>Documentación:</strong>
                        <a href="https://github.com/RaulParedes2/-IPC2_Proyecto2_202400554/tree/main/Documentacion" target="_blank">Documentacion</a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-secondary text-white">
        <h4>Guía de Funcionalidades</h4>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <h5>Gestión de Drones</h5>
                <ul>
                    <li>Ver listado de drones ordenado alfabéticamente</li>
                    <li>Agregar nuevos drones (nombre único)</li>
                    <li>Eliminar drones existentes</li>
                </ul>
                
                <h5>Gestión de Sistemas de Drones</h5>
                <ul>
                    <li>Crear sistemas de drones</li>
                    <li>Agregar drones a sistemas</li>
                    <li>Configurar tabla de codificación (dron + altura = letra)</li>
                    <li>Visualizar gráficamente con Graphviz</li>
                </ul>
            </div>
            <div class="col-md-6">
                <h5>Gestión de Mensajes</h5>
                <ul>
                    <li>Crear mensajes con instrucciones</li>
                    <li>Ver listado ordenado alfabéticamente</li>
                    <li>Enviar mensajes a sistemas de drones</li>
                    <li>Ver tiempo óptimo y mensaje recibido</li>
                    <li>Generar gráfico del plan de vuelo</li>
                </ul>
                
                <h5>Archivos XML</h5>
                <ul>
                    <li>Cargar configuración desde archivo XML</li>
                    <li>Generar XML de salida con resultados</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Volver al Inicio</a>
</div>